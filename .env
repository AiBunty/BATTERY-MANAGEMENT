APP_NAME=Battery Management
APP_ENV=local
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Kolkata

DB_HOST=mysql
DB_PORT=3306
DB_NAME=battery_db
DB_USER=app_user
DB_PASS=pass123

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0

QUEUE_DRIVER=redis
QUEUE_DEFAULT=emails

MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USER=
MAIL_PASS=
MAIL_FROM=no-reply@battery-local.test

JWT_SECRET=replace_with_64_hex_chars
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

TRACKING_URL_BASE=http://localhost:8000/track
TRACKING_TOKEN_TTL_DAYS=90
